        "text": "The doctor command initializes repo memory state, reports OPENAI_API_KEY source or missing setup, and can smoke-test OpenAI embeddings with --check-openai.",
        "truth": "code_verified",
        "intent": "intended",
        "about": [
          "flow.doctor_and_init",
          "component.cli_app",
          "component.env_loading",
          "component.graph_context_retrieval"
