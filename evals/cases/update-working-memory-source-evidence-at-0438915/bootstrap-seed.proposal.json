        "text": "Repo context detection derives the repo root, remote URL, repo name, and default branch from Git, falling back to local:<repoRoot> and main when Git remote metadata is unavailable.",
        "truth": "code_verified",
        "intent": "intended",
        "about": [
          "component.repo_context_detection",
          "flow.doctor_and_init"
        ]
      },
      {
        "id": "claim.greplica_home_precedence",
        "kind": "fact",
        "text": "The SQLite database path prefers GREPLICA_HOME, accepts legacy ENGINEERING_CONTEXT_HOME when GREPLICA_HOME is unset, and otherwise defaults to ~/.greplica/graph.db.",
        "truth": "code_verified",
        "intent": "intended",
        "about": [
          "component.sqlite_storage",
          "flow.doctor_and_init"
        ]
      },
      {
